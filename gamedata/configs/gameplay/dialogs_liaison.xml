<?xml version="1.0" encoding="windows-1251" ?>

<game_dialogs>


    <dialog id="raid_wild_mode">
        <phrase_list>
            <phrase id="0">
                <text>st_raid_wild_mode</text> <!-- Ключ вместо прямого текста -->
                <next>1</next>
            </phrase>
            <phrase id="1">
                <text>st_raid_wild_confirm</text> <!-- Ключ вместо прямого текста -->
                <next>10</next>
                <next>11</next>
            </phrase>
            <phrase id="10">
		<precondition>raid_wild_mode_main.check_wild_cooldown</precondition>
                <text>st_raid_yes</text> <!-- Ключ вместо прямого текста -->
                <action>raid_wild_mode_main.wild_mode_action</action>
                <action>dialogs.break_dialog</action>
            </phrase>
            <phrase id="11">
                <text>st_raid_no</text> <!-- Ключ вместо прямого текста -->
                <action>dialogs.break_dialog</action>
            </phrase>
        </phrase_list>
    </dialog>

	<dialog id="raid_liaison_get_info">
		<phrase_list>
			<phrase id="0">
				<text>st_raid_liaison_get_info</text>
				<next>1</next>
			</phrase>
			<phrase id="1">
				<text>st_raid_liaison_info</text>
				<next>10</next>
			</phrase>
			<phrase id="10">
				<text>st_raid_back</text>
				<next>0</next>
			</phrase>
		</phrase_list>
	</dialog>

</game_dialogs>