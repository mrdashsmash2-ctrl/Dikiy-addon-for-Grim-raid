[wild_mode_settings]
;---------------------------------------------------------------
; Основные настройки
;---------------------------------------------------------------
cost = 10000                     ; Стоимость использования режима дикого (в рублях)
cooldown_hours = 24            ; Время кулдауна в часах

;---------------------------------------------------------------
; Вероятности выдачи дополнительных категорий (в процентах 0-100)
;---------------------------------------------------------------
chance_helmet = 50             ; Шанс получить головной убор
chance_extra_meds = 40         ; Шанс получить дополнительные медикаменты
chance_junk = 50               ; Шанс получить разнообразный хлам
chance_tools = 30              ; Шанс получить инструменты
chance_knife = 40              ; Шанс получить нож
chance_backpack = 40           ; Шанс получить рюкзак
chance_grenade = 30            ; Шанс получить гранату
chance_food = 45               ; Шанс получить еду
chance_cigarettes = 40         ; Шанс получить сигареты
chance_extra_ammo = 40         ; Шанс получить дополнительные патроны
chance_weapon_modules = 30     ; Шанс получить модули для оружия

;---------------------------------------------------------------
; Диапазоны состояния выдаваемого снаряжения (от 0.0 до 1.0)
;---------------------------------------------------------------
weapon_condition_min = 0.60    ; Минимальное состояние оружия 
weapon_condition_max = 0.90    ; Максимальное состояние оружия 
armor_condition_min = 0.60     ; Минимальное состояние брони 
armor_condition_max = 0.90     ; Максимальное состояние брони 
helmet_condition_min = 0.60    ; Минимальное состояние шлема 
helmet_condition_max = 0.85    ; Максимальное состояние шлема 

