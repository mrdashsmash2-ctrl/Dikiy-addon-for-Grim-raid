-- НАЧАЛО КОДА РЕЖИМА ДИКОГО (от IvoryM(Discord: Pechenka), Claude & Grok)
-- Глобальная таблица для хранения конфигурации
local gt = game.translate_string

local wild_config = nil

-- Загрузка конфигурации из ltx файла
function load_wild_config()
    if wild_config then return wild_config end
    
    wild_config = {
        settings = {},
        weapons_cat1 = {},      -- Оружие с магазинами
        weapons_cat2 = {}, 
        weapons_cat3 = {},     -- Оружие без магазинов
        magazines = {},         -- Таблица магазинов для оружия
        ammo_types = {},        -- Типы патронов для оружия
        weapon_modules = {},    -- Модули для оружия
        armor = {},
        helmets = {},
        extra_meds = {},
        knives = {},
        backpacks = {},
        grenades = {},
        food = {},
        cigarettes = {},
        junk = {},
        tools = {},
        guaranteed = {}
    }

    local ini_file = ini_file("misc\\raid_wild_config.ltx")
    
    
    -- Загрузка основных настроек
    if ini_file:section_exist("wild_mode_settings") then
        wild_config.settings.cost = ini_file:r_float_ex("wild_mode_settings", "cost") or 1000
        wild_config.settings.cooldown_hours = ini_file:r_float_ex("wild_mode_settings", "cooldown_hours") or 24
        wild_config.settings.chance_helmet = ini_file:r_float_ex("wild_mode_settings", "chance_helmet") or 30
        wild_config.settings.chance_extra_meds = ini_file:r_float_ex("wild_mode_settings", "chance_extra_meds") or 40
        wild_config.settings.chance_junk = ini_file:r_float_ex("wild_mode_settings", "chance_junk") or 50
        wild_config.settings.chance_tools = ini_file:r_float_ex("wild_mode_settings", "chance_tools") or 15
        wild_config.settings.chance_knife = ini_file:r_float_ex("wild_mode_settings", "chance_knife") or 25
        wild_config.settings.chance_backpack = ini_file:r_float_ex("wild_mode_settings", "chance_backpack") or 20
        wild_config.settings.chance_grenade = ini_file:r_float_ex("wild_mode_settings", "chance_grenade") or 35
        wild_config.settings.chance_food = ini_file:r_float_ex("wild_mode_settings", "chance_food") or 45
        wild_config.settings.chance_cigarettes = ini_file:r_float_ex("wild_mode_settings", "chance_cigarettes") or 30
        wild_config.settings.chance_weapon_modules = ini_file:r_float_ex("wild_mode_settings", "chance_weapon_modules") or 20

        -- Загрузка настроек состояния снаряжения
        wild_config.settings.weapon_condition_min = ini_file:r_float_ex("wild_mode_settings", "weapon_condition_min") or 0.50
        wild_config.settings.weapon_condition_max = ini_file:r_float_ex("wild_mode_settings", "weapon_condition_max") or 0.85
        wild_config.settings.armor_condition_min = ini_file:r_float_ex("wild_mode_settings", "armor_condition_min") or 0.40
        wild_config.settings.armor_condition_max = ini_file:r_float_ex("wild_mode_settings", "armor_condition_max") or 0.80
        wild_config.settings.helmet_condition_min = ini_file:r_float_ex("wild_mode_settings", "helmet_condition_min") or 0.45
        wild_config.settings.helmet_condition_max = ini_file:r_float_ex("wild_mode_settings", "helmet_condition_max") or 0.85
    end
    
    -- Функция для чтения списка предметов из секции
    local function read_items_list(section_name)
        local items = {}
        if ini_file:section_exist(section_name) then
            local n = ini_file:line_count(section_name)
            for i = 0, n - 1 do
                local result, id, value = ini_file:r_line(section_name, i, "", "")
                if id ~= "" then
                    table.insert(items, id)
                end
            end
        end
        return items
    end
    
    -- Функция для чтения таблицы "ключ = значение1, значение2, значение3"
    local function read_items_table(section_name)
        local items_table = {}
        if ini_file:section_exist(section_name) then
            local n = ini_file:line_count(section_name)
            for i = 0, n - 1 do
                local result, id, value = ini_file:r_line(section_name, i, "", "")
                if id ~= "" and value ~= "" then
                    -- Разбиваем значения по запятым
                    local values = {}
                    for val in string.gmatch(value, "([^,]+)") do
                        table.insert(values, val:match("^%s*(.-)%s*$")) -- trim whitespace
                    end
                    items_table[id] = values
                end
            end
        end
        return items_table
    end
    
    -- Загрузка списков предметов
    wild_config.weapons_cat1 = read_items_list("wild_weapons_cat1")
    wild_config.weapons_cat2 = read_items_list("wild_weapons_cat2")
    wild_config.weapons_cat3 = read_items_list("wild_weapons_cat3")
    wild_config.magazines = read_items_table("wild_magazines")
    wild_config.ammo_types = read_items_table("wild_ammo_types")
    wild_config.weapon_modules = read_items_table("wild_weapon_modules")
    wild_config.armor = read_items_list("wild_armor")
    wild_config.helmets = read_items_list("wild_helmets")
    wild_config.extra_meds = read_items_list("wild_extra_meds")
    wild_config.knives = read_items_list("wild_knives")
    wild_config.backpacks = read_items_list("wild_backpacks")
    wild_config.grenades = read_items_list("wild_grenades")
    wild_config.food = read_items_list("wild_food")
    wild_config.cigarettes = read_items_list("wild_cigarettes")
    wild_config.junk = read_items_list("wild_junk")
    wild_config.tools = read_items_list("wild_tools")
    
    -- Загрузка гарантированных предметов
    if ini_file:section_exist("wild_guaranteed") then
        wild_config.guaranteed.medkit = ini_file:r_float_ex("wild_guaranteed", "medkit") or 1
        wild_config.guaranteed.bandage = ini_file:r_float_ex("wild_guaranteed", "bandage") or 2
        wild_config.guaranteed.vodka = ini_file:r_float_ex("wild_guaranteed", "vodka") or 1
	    wild_config.guaranteed.svet = ini_file:r_float_ex("wild_guaranteed", "svet") or 1
        wild_config.guaranteed.box = ini_file:r_float_ex("wild_guaranteed", "box") or 1
    end
    
    return wild_config
end

-- Получение случайного предмета из списка
function get_random_item(items_list)
    if not items_list or #items_list == 0 then return nil end
    local index = math.random(1, #items_list)
    return items_list[index]
end

-- Проверка вероятности (возвращает true, если событие должно произойти)
function check_chance(chance)
    return math.random(1, 100) <= chance
end

-- Выдача предмета игроку
function give_item_to_actor(section, count)
    count = count or 1
    for i = 1, count do
        alife():create(section, db.actor:position(), db.actor:level_vertex_id(), 
                      db.actor:game_vertex_id(), db.actor:id())
    end
end

-- Генерация случайного состояния в заданном диапазоне
function get_random_condition(min_cond, max_cond)
    min_cond = min_cond or 0.5
    max_cond = max_cond or 1.0
    
    if min_cond > max_cond then
        min_cond, max_cond = max_cond, min_cond
    end
    
    local range = max_cond - min_cond
    local random_value = min_cond + (math.random() * range)
    
    return math.max(0.01, math.min(1.0, random_value))
end

function give_item_with_condition(section, min_cond, max_cond, count)
    count = count or 1
    
    for i = 1, count do
        local condition = get_random_condition(min_cond, max_cond)
        
        local se_obj = alife():create(section, 
                                      db.actor:position(), 
                                      db.actor:level_vertex_id(), 
                                      db.actor:game_vertex_id(), 
                                      db.actor:id())
        
        if se_obj then
            -- Ждем чуть дольше для гарантии
            local obj_id = se_obj.id
            
            CreateTimeEvent("wild_mode_cond", "item_" .. obj_id, 0.1, function()
                local obj = level.object_by_id(obj_id)
                if obj and obj:section() == section then
                    obj:set_condition(condition)
                    
                    -- Простой вывод в лог
                    printf("[WILD_MODE] Item: " .. section .. " | Condition: " .. tostring(math.floor(condition * 100)) .. "%")
                end
                return true
            end)
        end
    end
end

-- Выдача оружия с рандомизированным состоянием
function give_weapon_with_condition(weapon_section, config)
    local condition = get_random_condition(
        config.settings.weapon_condition_min,
        config.settings.weapon_condition_max
    )
    
    local se_obj = alife():create(weapon_section, 
                                  db.actor:position(), 
                                  db.actor:level_vertex_id(), 
                                  db.actor:game_vertex_id(), 
                                  db.actor:id())
    
    if se_obj then
        local obj_id = se_obj.id
        
        CreateTimeEvent("wild_mode_weapon", "weapon_" .. obj_id, 0.1, function()
            local obj = level.object_by_id(obj_id)
            if obj and obj:section() == weapon_section then
                -- Устанавливаем общее состояние оружия
                obj:set_condition(condition)
                
                -- Рандомизация частей оружия через WPO (если установлен)
                randomize_weapon_parts(obj, condition)
                
                printf("[WILD_MODE] Weapon: %s | Condition: %s%% | Parts randomized", 
                       weapon_section, tostring(math.floor(condition * 100)))
            end
            return true
        end)
    end
end

-- Рандомизация состояния частей оружия (интеграция WPO)
function randomize_weapon_parts(wpn, weapon_condition)
    -- Проверяем, установлен ли WPO
    if not (wpo_loot and wpo_loot.has_parts and wpo_loot.get_parts_list) then
        return -- WPO не установлен, пропускаем
    end
    
    local has_parts = wpo_loot.has_parts(wpn)
    if not has_parts then
        return -- У оружия нет частей
    end
    
    local parts = wpo_loot.get_parts_list(wpn)
    if not parts or parts == "" then
        return
    end
    
    local parts_data = {}
    local con = math.ceil(weapon_condition * 100)
    
    -- Шанс получить хорошее состояние части зависит от общего состояния оружия
    -- Формула из wpo_loot.script: 25 + condition/2.5
    local final_chance =40 + math.ceil(con / 2.5)
    
    printf("[WILD_MODE WPO] Weapon parts randomization | Base chance: %s%%", final_chance)
    
    -- Парсим список частей
    for part in string.gmatch(parts, "[^,]+") do
        part = part:gsub("^%s*(.-)%s*$", "%1") -- trim whitespace
        
        -- Определяем, будет ли часть в хорошем или плохом состоянии
        local roll = math.random(100)
        local is_good = roll < final_chance
        
        -- Генерируем состояние части
        local part_condition
        if is_good then
            -- Хорошее состояние: 60-100%
            part_condition = math.random(60, 100)
        else
            -- Плохое состояние: 10-59%
            -- Есть шанс на отсутствующую часть (5%)
            if math.random(100) <= 5 then
                part_condition = -1 -- Часть отсутствует
            else
                part_condition = math.random(10, 59)
            end
        end
        
        parts_data[part] = part_condition
        
        printf("[WILD_MODE WPO] Part: %s | Condition: %s | Roll: %s/%s", 
               part, 
               part_condition == -1 and "MISSING" or (part_condition .. "%"),
               roll,
               final_chance)
    end
    
    -- Сохраняем состояние частей
    se_save_var(wpn:id(), wpn:name(), "parts", parts_data)
    
    printf("[WILD_MODE WPO] Weapon parts randomization complete for %s", wpn:section())
end

-- Выдача брони с рандомизированным состоянием
function give_armor_with_condition(armor_section, config)
    give_item_with_condition(
        armor_section,
        config.settings.armor_condition_min,
        config.settings.armor_condition_max,
        1
    )
end

-- Выдача шлема с рандомизированным состоянием
function give_helmet_with_condition(helmet_section, config)
    give_item_with_condition(
        helmet_section,
        config.settings.helmet_condition_min,
        config.settings.helmet_condition_max,
        1
    )
end


-- Выдача магазинов для оружия
function give_weapon_magazines(config, weapon_section, weapon_category)

    if not magazines then
        return -- Мод на магазины не установлен, пропускаем
    end
    
    -- Получаем ID магазина для этого оружия
    local mag_id = config.magazines[weapon_section]
    if not mag_id or #mag_id == 0 then
        return -- Если магазин не найден, пропускаем
    end
    
    -- Получаем первый магазин из списка (если их несколько)
    local magazine_section = type(mag_id) == "table" and mag_id[1] or mag_id
    
    -- Определяем количество магазинов в зависимости от категории
    -- Категория 1 (автоматы): 2 магазина
    -- Категория 3 (пистолеты): 3 магазина
    local mag_count = (weapon_category == 3) and 3 or 2
    
    -- Выдаём магазины
    give_item_to_actor(magazine_section, mag_count)
end

-- Выдача патронов для оружия
function give_weapon_ammo(config, weapon_section, weapon_category)
    -- Получаем типы патронов для этого оружия
    local ammo_list = config.ammo_types[weapon_section]
    if not ammo_list or #ammo_list == 0 then
        return -- Если патроны не найдены, пропускаем
    end
    
    -- Определяем количество типов патронов для выдачи в зависимости от категории
    -- Категория 1 (автоматы): 6 пачек (по 2 каждого типа, максимум 3 типа)
    -- Категория 2 (без магазинов): 4 пачки (по 2 каждого типа, максимум 2 типа)
    -- Категория 3 (пистолеты): 6 пачек (по 2 каждого типа, максимум 3 типа)
    local types_count
    if weapon_category == 2 then
        types_count = math.min(2, #ammo_list)  -- Категория 2: 4 пачки (2 типа)
    else
        types_count = math.min(3, #ammo_list)  -- Категории 1 и 3: 6 пачек (3 типа)
    end
    
    -- Перемешиваем список патронов для рандомизации
    local shuffled_ammo = {}
    for i, ammo in ipairs(ammo_list) do
        table.insert(shuffled_ammo, ammo)
    end
    
    -- Простое перемешивание
    for i = #shuffled_ammo, 2, -1 do
        local j = math.random(i)
        shuffled_ammo[i], shuffled_ammo[j] = shuffled_ammo[j], shuffled_ammo[i]
    end
    
    -- Выдаём по 2 пачки каждого типа
    for i = 1, types_count do
        give_item_to_actor(shuffled_ammo[i], 2)
    end
end

-- Выдача модулей для оружия
function give_weapon_modules(config, weapon_section)
    -- Получаем список модулей для этого оружия
    local modules_list = config.weapon_modules[weapon_section]
    
    -- Выдаём случайный модуль из списка
    local module = get_random_item(modules_list)
    if module then
        give_item_to_actor(module, 1)
    end
end

-- Основная функция выдачи предметов
function wild_mode_action(actor, npc)
    -- Загрузка конфигурации
    local config = load_wild_config()
    
    -- Проверка денег
    if actor:money() < config.settings.cost then
        news_manager.send_tip(actor, gt("st_raid_bbnomoney"), nil, nil, 5000)
        return
    end
    
    -- Списание денег
    actor:give_money(-config.settings.cost)
    
    -- =====================================================
    -- ВЫДАЧА ГАРАНТИРОВАННЫХ ПРЕДМЕТОВ
    -- =====================================================
    
    -- Выбор категории оружия (случайно между категориями 1, 2 и 3)
    local weapon_section = nil
    local weapon_category = 1
    
    -- Проверка модового оружия через существование секций и добавление к списку категории 2
    if ini_sys:section_exist("wpn_izh18") then
        table.insert(config.weapons_cat2, "wpn_izh18")
        printf("[WILD MODE] Added wpn_izh18 to category 2")
    end
    if ini_sys:section_exist("wpn_mp18") then
        table.insert(config.weapons_cat2, "wpn_mp18")
        printf("[WILD MODE] Added wpn_mp18 to category 2")
    end

    -- Объединяем все три списка оружия
    local all_weapons = {}
    for _, wpn in ipairs(config.weapons_cat1) do
        table.insert(all_weapons, {section = wpn, category = 1})
    end
    for _, wpn in ipairs(config.weapons_cat2) do
        table.insert(all_weapons, {section = wpn, category = 2})
    end
    for _, wpn in ipairs(config.weapons_cat3) do
        table.insert(all_weapons, {section = wpn, category = 3})
    end
    
    -- Выбираем случайное оружие
    if #all_weapons > 0 then
        local weapon_data = get_random_item(all_weapons)
        weapon_section = weapon_data.section
        weapon_category = weapon_data.category
        
        -- Выдаём оружие
        give_weapon_with_condition(weapon_section, config)
        
        -- Выдаём магазины (для категорий 1 и 3)
        if weapon_category == 1 or weapon_category == 3 then
            give_weapon_magazines(config, weapon_section, weapon_category)
        end
        
        -- Выдаём патроны
        give_weapon_ammo(config, weapon_section, weapon_category)
    end
    
    -- Броня (1 случайная) с рандомизированным состоянием
    local armor = get_random_item(config.armor)
    if armor then
        give_armor_with_condition(armor, config)
    end
    
    -- Гарантированные медикаменты и расходники
    give_item_to_actor("medkit", config.guaranteed.medkit)
    give_item_to_actor("bandage", config.guaranteed.bandage)
    give_item_to_actor("vodka", config.guaranteed.vodka)
    give_item_to_actor("device_glowstick", config.guaranteed.svet)
    give_item_to_actor("faction_changer_box", config.guaranteed.box)
    
    -- =====================================================
    -- ВЫДАЧА СЛУЧАЙНЫХ ДОПОЛНИТЕЛЬНЫХ ПРЕДМЕТОВ
    -- =====================================================
    
    -- Головной убор (с шансом) с рандомизированным состоянием
    if check_chance(config.settings.chance_helmet) then
        local helmet = get_random_item(config.helmets)
        if helmet then
            give_helmet_with_condition(helmet, config)
        end
    end
    
    -- Дополнительные медикаменты (с шансом)
    if check_chance(config.settings.chance_extra_meds) then
        local extra_med = get_random_item(config.extra_meds)
        if extra_med then
            give_item_to_actor(extra_med)
        end
    end
    
    
    -- Нож (с шансом)
    if check_chance(config.settings.chance_knife) then
        local knife = get_random_item(config.knives)
        if knife then
            give_item_to_actor(knife)
        end
    end
    
    -- Рюкзак (с шансом)
    if check_chance(config.settings.chance_backpack) then
        local backpack = get_random_item(config.backpacks)
        if backpack then
            give_item_to_actor(backpack)
        end
    end
    
    -- Граната (с шансом)
    if check_chance(config.settings.chance_grenade) then
        local grenade = get_random_item(config.grenades)
        if grenade then
            give_item_to_actor(grenade, 1)
        end
    end
    
    -- Еда (с шансом)
    if check_chance(config.settings.chance_food) then
        local food = get_random_item(config.food)
        if food then
            give_item_to_actor(food, 1)
        end
    end
    
    -- Сигареты (с шансом)
    if check_chance(config.settings.chance_cigarettes) then
        local cigs = get_random_item(config.cigarettes)
        if cigs then
            give_item_to_actor(cigs, 1)
        end
    end
    
    -- Хлам (с шансом)
    if check_chance(config.settings.chance_junk) then
        local junk_item = get_random_item(config.junk)
        if junk_item then
            give_item_to_actor(junk_item)
        end
    end
    
    -- Инструменты (с шансом)
    if check_chance(config.settings.chance_tools) then
        local tool = get_random_item(config.tools)
        if tool then
            give_item_to_actor(tool)
        end
    end
    
    -- Модули для оружия (с шансом)
    if weapon_section and check_chance(config.settings.chance_weapon_modules) then
        give_weapon_modules(config, weapon_section)
    end
    
    -- Установка времени последнего использования
    db.storage[0].pstor_ctime = db.storage[0].pstor_ctime or {}
    db.storage[0].pstor_ctime["last_wild_time"] = game.get_game_time()
    
end

-- Проверка кулдауна
function check_wild_cooldown(actor, npc)
    if not db.storage[0].pstor_ctime or not db.storage[0].pstor_ctime["last_wild_time"] then
        return true
    end
    
    local config = load_wild_config()
    local last_time = db.storage[0].pstor_ctime["last_wild_time"]
    local seconds_passed = game.get_game_time():diffSec(last_time)
    local hours_passed = seconds_passed / 3600
    
    if hours_passed < config.settings.cooldown_hours then
        news_manager.send_tip(actor, gt("st_raid_wild_cooldown"), nil, nil, 5000)
        return false
    end
    
    return true
end